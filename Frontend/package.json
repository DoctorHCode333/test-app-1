{
  "name": "voya-client-app",
  "private": true,
  "version": "0.0.0",
  "homepage": "VOYA_CLIENT_APP",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:v1.0.0": "cross-env VERSION=1.0.0 npm run build",
    "build:v2.0.0": "cross-env VERSION=2.0.0 npm run build",
    "build:latest": "cross-env VERSION=latest npm run build",
    "predeploy": "npm run build:latest",
    "deploy": "npm run copy:latest && gh-pages -d dist",
    "copy:latest": "xcopy /E /I /Y dist\\vlatest\\* dist\\",
    "deploy:versions": "npm run build && git add dist && git commit -m 'Deploy new versions' && git push origin versions",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@material-tailwind/react": "^2.1.9",
    "@mui/icons-material": "^5.16.13",
    "@mui/material": "^5.18.0",
    "@mui/system": "^6.3.1",
    "@mui/x-charts": "^7.12.1",
    "@mui/x-data-grid": "^7.8.0",
    "@mui/x-date-pickers": "^7.29.4",
    "@mui/x-tree-view": "^7.8.0",
    "@reduxjs/toolkit": "^2.2.6",
    "axios": "^1.6.8",
    "buffer": "^6.0.3",
    "chart.js": "^4.4.3",
    "chartjs-plugin-zoom": "^2.0.1",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^11.16.0",
    "lucide-react": "^0.483.0",
    "papaparse": "^5.5.2",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.6",
    "prop-types": "^15.8.1",
    "purecloud-platform-client-v2": "^196.0.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "react-loader-spinner": "^6.1.6",
    "react-redux": "^9.1.1",
    "react-router-dom": "^6.23.1",
    "react-spring": "^9.7.5",
    "react-tailwind-datepicker": "^0.0.1",
    "react-tailwindcss-datepicker": "^1.6.6",
    "recharts": "^2.15.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0"
